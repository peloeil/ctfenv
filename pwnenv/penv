#!/usr/bin/env bash

set -euo pipefail

die() {
    printf 'penv: %s\n' "$*" >&2
    exit 1
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STATE_FILE=".penv-state"

state_record_created() {
    printf 'created\t%s\n' "$1" >>"$STATE_FILE"
}

state_record_rename() {
    printf 'renamed\t%s\t%s\n' "$1" "$2" >>"$STATE_FILE"
}

# -------------------------------------

# penv help
penv_help() {
    cat <<USAGE
Usage:
    penv (help|--help|-h)
    penv init (bare|stack|heap|kernel)
    penv info
    penv check
    penv clean
USAGE
}

detect_compose_file() {
    local f

    for f in compose.yaml compose.yml docker-compose.yml docker-compose.yaml; do
        if [ -f "$f" ]; then
            printf '%s\n' "$f"
            return 0
        fi
    done
    return 1
}

normalize_compose_file() {
    local compose_file

    compose_file="$(detect_compose_file || true)"
    [ -n "$compose_file" ] || return 1

    if [ "$compose_file" != "compose.yaml" ]; then
        mv "$compose_file" compose.yaml
        state_record_rename "$compose_file" "compose.yaml"
    fi
    return 0
}

get_service_name() {
    local compose_file="${1:-compose.yaml}"

    [ -f "$compose_file" ] || return 1
    awk '
        /^services:/ { in_services = 1; next }
        in_services && match($0, /^[[:space:]]{2}([A-Za-z0-9_.-]+):/, m) {
            if (m[1] != "pwnenv") {
                print m[1]
                exit
            }
        }
        in_services && /^[^[:space:]]/ { exit }
    ' "$compose_file"
}

get_ubuntu_version_optional() {
    local dockerfile="$1"
    local tag

    tag="$(awk '
        /^ARG[[:space:]]+[A-Za-z_][A-Za-z0-9_]*=/ {
            line = $0
            sub(/^ARG[[:space:]]+/, "", line)
            name = line
            sub(/=.*/, "", name)
            value = line
            sub(/^[^=]*=/, "", value)
            gsub(/["'\'' ]/, "", value)
            args[name] = value
            next
        }
        /^FROM[[:space:]]+ubuntu:/ {
            line = $0
            sub(/^FROM[[:space:]]+ubuntu:/, "", line)
            sub(/[[:space:]]+AS[[:space:]].*$/, "", line)
            sub(/[[:space:]].*$/, "", line)
            sub(/@.*/, "", line)
            gsub(/["'\'']/, "", line)

            if (match(line, /^\$\{([A-Za-z_][A-Za-z0-9_]*)\}$/, m) && (m[1] in args)) {
                line = args[m[1]]
            } else if (match(line, /^\$([A-Za-z_][A-Za-z0-9_]*)$/, m) && (m[1] in args)) {
                line = args[m[1]]
            }

            print line
            exit
        }
    ' "$dockerfile")"
    [ -n "$tag" ] || return 1
    printf '%s\n' "$tag"
}

get_ubuntu_version() {
    local dockerfile="$1"
    local tag

    tag="$(get_ubuntu_version_optional "$dockerfile" || true)"
    [ -n "$tag" ] || die "ubuntu version not found in $dockerfile"
    printf '%s\n' "$tag"
}

get_service_port() {
    local service_name="$1"
    local compose_file="${2:-compose.yaml}"
    local port

    if [ ! -f "$compose_file" ]; then
        printf '%s\n' "9999"
        return 0
    fi

    port="$(awk -v svc="$service_name" '
        /^services:/ { in_services = 1; next }
        in_services && match($0, /^[[:space:]]{2}([A-Za-z0-9_.-]+):/, m) {
            in_service = (svc == "" || m[1] == svc)
            in_ports = 0
            next
        }
        in_service && $1 == "ports:" { in_ports = 1; next }
        in_service && in_ports && $1 == "-" {
            value = $0
            sub(/^[[:space:]]*-[[:space:]]*/, "", value)
            print value
            exit
        }
        in_service && /^[^[:space:]]/ { exit }
    ' "$compose_file")"

    port="$(printf '%s' "$port" | tr -d "\"'")"
    port="${port%%/*}"
    port="${port##*:}"
    if [ -n "$port" ]; then
        printf '%s\n' "$port"
    else
        printf '%s\n' "9999"
    fi
}

compose_has_pwnenv() {
    local compose_file="${1:-compose.yaml}"

    [ -f "$compose_file" ] || return 1
    grep -qE '^[[:space:]]{2}pwnenv:' "$compose_file" || return 1
}

load_compose_context() {
    local service_name_var="$1"
    local port_var="$2"
    local detected_service_name=""

    if normalize_compose_file; then
        detected_service_name="$(get_service_name compose.yaml || true)"
    fi

    printf -v "$service_name_var" '%s' "$detected_service_name"
    printf -v "$port_var" '%s' "$(get_service_port "$detected_service_name" compose.yaml)"
}

copy_mode_file_if_missing() {
    local mode_dir="$1"
    local src="$2"
    local dst="${3:-$2}"
    local created_var="${4:-}"
    local created="0"

    if [ ! -e "$dst" ]; then
        cp -p "$SCRIPT_DIR/$mode_dir/$src" "$dst"
        state_record_created "$dst"
        created="1"
    fi

    if [ -n "$created_var" ]; then
        printf -v "$created_var" '%s' "$created"
    fi
}

copy_mode_dir_if_missing() {
    local mode_dir="$1"
    local src="$2"
    local dst="${3:-$2}"

    if [ ! -e "$dst" ]; then
        cp -rp "$SCRIPT_DIR/$mode_dir/$src" "$dst"
        state_record_created "$dst"
    fi
}

ensure_bare_dockerfile() {
    local created_var="${1:-}"
    local created="0"

    if [ ! -e bare.Dockerfile ]; then
        sed 's#/home/pwn/stack#/home/pwn/bare#g' "$SCRIPT_DIR/stack/stack.Dockerfile" >bare.Dockerfile
        state_record_created "bare.Dockerfile"
        created="1"
    fi

    if [ -n "$created_var" ]; then
        printf -v "$created_var" '%s' "$created"
    fi
}

write_pwnenv_snippet() {
    local out="$1"
    local dockerfile="$2"
    local service_name="$3"
    local version="$4"
    local share_network="${5:-0}"
    local with_kvm="${6:-0}"

    {
        echo "  pwnenv:"
        echo "    build:"
        echo "      context: ."
        echo "      dockerfile: ${dockerfile}"
        if [ -n "$version" ]; then
            echo "      args:"
            echo "        VERSION: \"${version}\""
        fi
        if [ -n "$service_name" ]; then
            echo "    pid: \"service:${service_name}\""
            if [ "$share_network" = "1" ]; then
                echo "    network_mode: \"service:${service_name}\""
            fi
            echo "    cap_add:"
            echo "      - \"SYS_PTRACE\""
            echo "    depends_on:"
            echo "      - \"${service_name}\""
        else
            echo "    cap_add:"
            echo "      - \"SYS_PTRACE\""
        fi
        echo "    stdin_open: true"
        echo "    tty: true"
        if [ "$with_kvm" = "1" ]; then
            echo "    devices:"
            echo "      - /dev/kvm:/dev/kvm"
        fi
        echo "    volumes:"
        echo "      - type: bind"
        echo "        source: ./tmux.conf"
        echo "        target: /home/pwn/.tmux.conf"
        echo "      - type: bind"
        echo "        source: ./"
        echo "        target: /home/pwn/${dockerfile%.Dockerfile}"
    } >"$out"
}

insert_snippet_under_services() {
    local compose_file="$1"
    local snippet_file="$2"
    local tmp

    tmp="$(mktemp)"
    awk -v snippet="$snippet_file" '
        function emit_snippet(   line) {
            if (inserted) {
                return
            }
            while ((getline line < snippet) > 0) {
                print line
            }
            close(snippet)
            inserted = 1
        }

        BEGIN {
            found_services = 0
            in_services = 0
            inserted = 0
        }

        /^services:[[:space:]]*$/ {
            found_services = 1
            in_services = 1
            print
            next
        }

        in_services && /^[^[:space:]]/ {
            emit_snippet()
            in_services = 0
        }

        {
            print
        }

        END {
            if (!found_services) {
                print "services:"
                emit_snippet()
            } else if (in_services) {
                emit_snippet()
            }
        }
    ' "$compose_file" >"$tmp"
    mv "$tmp" "$compose_file"
}

add_pwnenv_service() {
    local dockerfile="$1"
    local service_name="$2"
    local version="$3"
    local share_network="${4:-0}"
    local with_kvm="${5:-0}"
    local snippet

    compose_has_pwnenv compose.yaml && return 0

    snippet="$(mktemp)"
    write_pwnenv_snippet "$snippet" "$dockerfile" "$service_name" "$version" "$share_network" "$with_kvm"
    insert_snippet_under_services compose.yaml "$snippet"
    rm -f "$snippet"
}

ensure_compose_with_pwnenv() {
    local dockerfile="$1"
    local service_name="$2"
    local version="${3:-}"
    local share_network="${4:-0}"
    local with_kvm="${5:-0}"
    local snippet

    if [ -f compose.yaml ]; then
        add_pwnenv_service "$dockerfile" "$service_name" "$version" "$share_network" "$with_kvm"
        return 0
    fi

    snippet="$(mktemp)"
    write_pwnenv_snippet "$snippet" "$dockerfile" "" "" "$share_network" "$with_kvm"
    {
        echo "services:"
        cat "$snippet"
    } >compose.yaml
    rm -f "$snippet"
    state_record_created "compose.yaml"
}

copy_mode_files_if_missing() {
    local mode_dir="$1"
    shift
    local path

    for path in "$@"; do
        copy_mode_file_if_missing "$mode_dir" "$path"
    done
}

remove_pwnenv_service() {
    local tmp

    [ -f compose.yaml ] || return 0
    tmp="$(mktemp)"
    awk '
        BEGIN { skip = 0 }
        /^  pwnenv:/ { skip = 1; next }
        skip {
            if (match($0, /^[[:space:]]{2}[A-Za-z0-9_.-]+:/)) {
                skip = 0
                print
            }
            next
        }
        { print }
    ' compose.yaml >"$tmp"
    mv "$tmp" compose.yaml
}

escape_sed() {
    printf '%s' "$1" | sed 's/[&/]/\\&/g'
}

replace_placeholders() {
    local path="$1"
    local binary="$2"
    local service="$3"
    local port="${4:-}"

    if [ -n "$binary" ] && grep -q '<binary-name>' "$path"; then
        sed -i "s/<binary-name>/$(escape_sed "$binary")/g" "$path"
    fi
    if [ -n "$service" ] && grep -q '<service-name>' "$path"; then
        sed -i "s/<service-name>/$(escape_sed "$service")/g" "$path"
    fi
    if [ -n "$port" ] && grep -q '<port>' "$path"; then
        sed -i "s/<port>/${port}/g" "$path"
    fi
}

detect_binary_optional() {
    local f name

    for f in ./*; do
        [ -f "$f" ] || continue
        name="${f#./}"
        case "$name" in
        *.py | *.sh | *.yaml | *.yml | *.md | *.txt | *.Dockerfile | Dockerfile | libc.so.6 | ld-linux-* | *.so | *.cpio* | bzImage | vmlinux | compose.yaml | compose.yml | docker-compose.yml | docker-compose.yaml | penv)
            continue
            ;;
        esac
        if file -b "$name" | grep -q 'ELF .* executable'; then
            printf '%s\n' "$name"
            return 0
        fi
    done
    return 1
}

detect_binary() {
    detect_binary_optional || die "binary not found"
}

ensure_libc_name() {
    local f

    if [ -f libc.so.6 ]; then
        return 0
    fi
    f="$(find . -maxdepth 1 -type f \( -name 'libc.so*' -o -name 'libc-*.so*' \) -print | head -n1 || true)"
    [ -n "$f" ] || return 1
    mv "${f#./}" libc.so.6
    state_record_rename "${f#./}" "libc.so.6"
}

ensure_libc_available() {
    local service_name="$1"

    if ensure_libc_name; then
        return 0
    fi

    [ -f compose.yaml ] || die "libc.so.6 not found"
    [ -n "$service_name" ] || die "service not found in compose.yaml"
    extract_libc_from_container "$service_name"
    ensure_libc_name || die "libc.so.6 not found"
}

run_pwninit() {
    command -v pwninit >/dev/null 2>&1 || die "pwninit not found"
    pwninit --bin "./$1" --libc ./libc.so.6
    rm -f solve.py
}

detect_patched_binary() {
    local binary="$1"
    local patched="${binary}_patched"

    [ -f "$patched" ] || die "patched binary not found: $patched"
    printf '%s\n' "$patched"
}

prepare_patched_binary() {
    local binary="$1"
    local patched="${binary}_patched"
    local before_ld=""
    local after_ld=""

    if [ -f "$patched" ]; then
        printf '%s\n' "$patched"
        return 0
    fi

    before_ld="$(detect_ld_file || true)"
    run_pwninit "$binary"
    ensure_libc_name || die "libc.so.6 not found"
    after_ld="$(detect_ld_file || true)"
    if [ -n "$after_ld" ] && [ -z "$before_ld" ]; then
        state_record_created "$after_ld"
    fi
    state_record_created "$patched"
    detect_patched_binary "$binary"
}

extract_libc_from_container() {
    local service_name="$1"

    docker compose -f compose.yaml run --rm --no-deps -T "$service_name" \
        sh -c "cat /lib/x86_64-linux-gnu/libc.so.6 || cat /lib64/libc.so.6 || cat /lib/libc.so.6" >libc.so.6
    state_record_created "libc.so.6"
}

detect_ld_file() {
    local f

    f="$(ls -1 ld-*.so* 2>/dev/null | head -n1 || true)"
    [ -n "$f" ] || return 1
    printf '%s\n' "$f"
}

ensure_tmux_conf() {
    if [ -f tmux.conf ]; then
        return 0
    fi
    cp -p "$SCRIPT_DIR/tmux.conf" tmux.conf
    state_record_created "tmux.conf"
}

ensure_run_script() {
    [ -f run.sh ] || die "run.sh not found"
}

ensure_bare_exploit_template() {
    local created_var="${1:-}"
    local created="0"

    if [ -f exploit.py ]; then
        if [ -n "$created_var" ]; then
            printf -v "$created_var" '%s' "$created"
        fi
        return 0
    fi

    cat <<'EOF' >exploit.py
#!/usr/bin/env -S uv run
# /// script
# dependencies = [
#     "ptrlib",
# ]
# ///

from ptrlib import *

elf = ELF("./<binary-name>")
io = Process("./<binary-name>")
#io = Socket("<service-name>", <port>)

io.interactive()
EOF
    chmod +x exploit.py
    state_record_created "exploit.py"
    created="1"

    if [ -n "$created_var" ]; then
        printf -v "$created_var" '%s' "$created"
    fi
}

strip_trailing_newlines() {
    local path="$1"
    local last_byte

    while [ -s "$path" ]; do
        last_byte="$(tail -c1 "$path")"
        if [ -z "$last_byte" ]; then
            truncate -s -1 "$path"
            continue
        fi
        break
    done
}

make_dev_sh() {
    if [ -f dev.sh ]; then
        return 0
    fi

    cp run.sh dev.sh
    sed -i "s/rootfs/rootfs_dev/g" dev.sh
    if ! grep -qE '(^|[[:space:]])-s([[:space:]]|$)' dev.sh; then
        strip_trailing_newlines dev.sh
        if ! tail -n1 dev.sh | grep -q '\\$'; then
            printf ' \\\n' >>dev.sh
        else
            printf '\n' >>dev.sh
        fi
        printf '    -s\n' >>dev.sh
    fi
    chmod +x dev.sh
    state_record_created "dev.sh"
}

detect_cpio_file() {
    local f

    if [ -f rootfs.cpio ]; then
        printf '%s\n' "rootfs.cpio"
        return 0
    fi

    f="$(find . -maxdepth 1 -type f \( -name '*.cpio' -o -name '*.cpio.gz' -o -name '*.cpio.xz' -o -name '*.cpio.lz4' \) -print | head -n1 || true)"
    [ -n "$f" ] || return 1
    printf '%s\n' "${f#./}"
}

detect_ext_file() {
    local f
    local ext

    for ext in ext2 ext3 ext4; do
        if [ -f "rootfs.${ext}" ]; then
            printf '%s\n' "rootfs.${ext}"
            return 0
        fi
    done

    f="$(find . -maxdepth 1 -type f \( -name '*.ext2' -o -name '*.ext3' -o -name '*.ext4' \) -print | head -n1 || true)"
    [ -n "$f" ] || return 1
    printf '%s\n' "${f#./}"
}

prepare_kernel_rootfs() {
    local rootfs_kind_var="$1"
    local rootfs_file_var="$2"
    local cpio_file ext_file ext_type rootfs_file="" rootfs_kind=""

    cpio_file="$(detect_cpio_file || true)"
    if [ -n "$cpio_file" ]; then
        rootfs_kind="cpio"
        rootfs_file="$cpio_file"
        extract_cpio_to_rootdir "$rootfs_file"
    else
        ext_file="$(detect_ext_file || true)"
        if [ -n "$ext_file" ]; then
            ext_type="${ext_file##*.}"
            rootfs_kind="$ext_type"
            rootfs_file="$ext_file"
            extract_ext_to_rootdir "$rootfs_file"
        fi
    fi

    printf -v "$rootfs_kind_var" '%s' "$rootfs_kind"
    printf -v "$rootfs_file_var" '%s' "$rootfs_file"
}

prepare_kernel_dev_rootfs() {
    local rootfs_kind="$1"
    local rootfs_file="$2"

    if [ "$rootfs_kind" = "cpio" ]; then
        touch rootfs_dev.cpio
    elif [ -n "$rootfs_kind" ] && [ -f "$rootfs_file" ] && [ ! -f "rootfs_dev.${rootfs_kind}" ]; then
        cp -p "$rootfs_file" "rootfs_dev.${rootfs_kind}"
    fi
}

detect_cpio_compression() {
    local cpio_file="$1"
    local mime

    mime="$(file -b --mime-type "$cpio_file" 2>/dev/null || true)"
    case "$mime" in
    application/gzip)
        printf '%s\n' "gz"
        ;;
    application/x-xz)
        printf '%s\n' "xz"
        ;;
    application/x-lz4)
        printf '%s\n' "lz4"
        ;;
    *)
        return 1
        ;;
    esac
}

extract_cpio_to_rootdir() {
    local cpio_file="$1"
    local compression=""

    rm -rf rootdir
    mkdir -p rootdir
    case "$cpio_file" in
    *.gz)
        compression="gz"
        ;;
    *.xz)
        compression="xz"
        ;;
    *.lz4)
        compression="lz4"
        ;;
    *)
        compression="$(detect_cpio_compression "$cpio_file" || true)"
        ;;
    esac

    case "$compression" in
    gz)
        gzip -dc "$cpio_file" | (cd rootdir && cpio -idv) || true
        ;;
    xz)
        xz -dc "$cpio_file" | (cd rootdir && cpio -idv) || true
        ;;
    lz4)
        lz4 -dc "$cpio_file" | (cd rootdir && cpio -idv) || true
        ;;
    *)
        (cd rootdir && cpio -idv <"../$cpio_file") || true
        ;;
    esac
}

extract_ext_to_rootdir() {
    local ext_file="$1"

    command -v debugfs >/dev/null 2>&1 || die "debugfs not found"
    rm -rf rootdir
    mkdir -p rootdir
    debugfs -R "rdump / rootdir" "$ext_file" || true
}

ensure_kernel_exploit_c() {
    if [ -f src/exploit.c ]; then
        return 0
    fi
    mkdir -p src
    cp -p "$SCRIPT_DIR/kernel/exploit.c" src/exploit.c
    state_record_created "src/exploit.c"
    copy_mode_dir_if_missing kernel template src/template
}

extract_vmlinux() {
    if [ -f vmlinux ] || [ ! -f bzImage ]; then
        return 0
    fi
    extract-vmlinux bzImage >vmlinux
}

# penv info
penv_info() {
    local binary service_name port ld_file ubuntu_version patched

    if normalize_compose_file; then
        service_name="$(get_service_name)"
    else
        service_name=""
    fi
    port="$(get_service_port "$service_name")"

    if binary="$(detect_binary_optional)"; then
        :
    else
        binary=""
    fi
    if [ -n "$binary" ] && [ -f "${binary}_patched" ]; then
        patched="${binary}_patched"
    else
        patched=""
    fi

    ld_file="$(detect_ld_file || true)"

    if [ -f Dockerfile ]; then
        ubuntu_version="$(awk '/^FROM[[:space:]]+ubuntu:[^@]+@/ { sub(/^FROM[[:space:]]+ubuntu:/, ""); sub(/@.*/, ""); print; exit }' Dockerfile)"
        ubuntu_version="$(printf '%s' "$ubuntu_version" | tr -d "\"'")"
    else
        ubuntu_version=""
    fi

    printf 'binary: %s\n' "${binary:-missing}"
    printf 'patched: %s\n' "${patched:-missing}"
    printf 'libc: %s\n' "$([ -f libc.so.6 ] && echo libc.so.6 || echo missing)"
    printf 'ld: %s\n' "${ld_file:-missing}"
    printf 'dockerfile: %s\n' "$([ -f Dockerfile ] && echo Dockerfile || echo missing)"
    [ -n "$ubuntu_version" ] && printf 'ubuntu: %s\n' "$ubuntu_version"
    printf 'compose: %s\n' "$([ -f compose.yaml ] && echo compose.yaml || echo missing)"
    printf 'service: %s\n' "${service_name:-missing}"
    printf 'port: %s\n' "${port:-missing}"
}

# penv check
penv_check() {
    local binary cpio_file ext_file mode

    if [ -f bzImage ] || detect_cpio_file >/dev/null 2>&1 || detect_ext_file >/dev/null 2>&1; then
        mode="kernel"
    elif [ -f libc.so.6 ]; then
        if [ -f Dockerfile ]; then
            mode="stack or heap"
        else
            mode="stack"
        fi
    else
        mode="bare"
    fi

    if binary="$(detect_binary_optional)"; then
        :
    else
        binary=""
    fi

    printf 'mode: %s\n' "$mode"
    printf 'binary: %s\n' "${binary:-missing}"
    printf 'libc: %s\n' "$([ -f libc.so.6 ] && echo present || echo missing)"
    printf 'dockerfile: %s\n' "$([ -f Dockerfile ] && echo present || echo missing)"
    printf 'compose: %s\n' "$([ -f compose.yaml ] && echo present || echo missing)"
    printf 'bzImage: %s\n' "$([ -f bzImage ] && echo present || echo missing)"
    printf 'run.sh: %s\n' "$([ -f run.sh ] && echo present || echo missing)"
    if cpio_file="$(detect_cpio_file 2>/dev/null)"; then
        printf 'cpio: %s\n' "$cpio_file"
    else
        printf 'cpio: missing\n'
    fi
    if ext_file="$(detect_ext_file 2>/dev/null)"; then
        printf 'ext: %s\n' "$ext_file"
    else
        printf 'ext: missing\n'
    fi

    printf 'deps:\n'
    for d in bash awk sed grep find file cpio docker pwninit extract-vmlinux; do
        if command -v "$d" >/dev/null 2>&1; then
            printf '  %s: ok\n' "$d"
        else
            printf '  %s: missing\n' "$d"
        fi
    done
    if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
        printf '  docker compose: ok\n'
    else
        printf '  docker compose: missing\n'
    fi
    for d in gzip xz lz4; do
        if command -v "$d" >/dev/null 2>&1; then
            printf '  %s (optional): ok\n' "$d"
        else
            printf '  %s (optional): missing\n' "$d"
        fi
    done
    for d in debugfs mke2fs; do
        if command -v "$d" >/dev/null 2>&1; then
            printf '  %s (ext2/3/4): ok\n' "$d"
        else
            printf '  %s (ext2/3/4): missing\n' "$d"
        fi
    done
}

# penv clean
penv_clean() {
    local ts

    if [ -f exploit.py ]; then
        ts="$(date +%Y%m%d%H%M%S)"
        cp -p exploit.py "exploit.py.bak.${ts}"
        rm -f exploit.py
    fi

    remove_pwnenv_service

    rm -f \
        bare.Dockerfile \
        stack.Dockerfile \
        heap.Dockerfile \
        kernel.Dockerfile \
        gdb.py \
        attach.sh \
        dev.sh \
        upload.py \
        solve.py \
        rootfs_dev.cpio \
        rootfs_dev.ext2 \
        rootfs_dev.ext3 \
        rootfs_dev.ext4 \
        *_patched
}

# penv init
penv_init_bare() {
    local binary created_exploit service_name port template_service

    binary="$(detect_binary)"

    ensure_bare_dockerfile
    copy_mode_file_if_missing stack Makefile Makefile
    ensure_bare_exploit_template created_exploit
    load_compose_context service_name port
    template_service="${service_name:-localhost}"
    if [ "$created_exploit" = "1" ]; then
        replace_placeholders "exploit.py" "$binary" "$template_service" "$port"
    fi
    ensure_tmux_conf
    ensure_compose_with_pwnenv "bare.Dockerfile" "$service_name" "" "0" "0"
}

penv_init_stack() {
    local binary created_exploit patched_binary service_name port template_service

    binary="$(detect_binary)"

    copy_mode_file_if_missing stack stack.Dockerfile stack.Dockerfile
    copy_mode_file_if_missing stack Makefile Makefile
    copy_mode_file_if_missing stack exploit.py exploit.py created_exploit
    load_compose_context service_name port
    ensure_libc_available "$service_name"
    patched_binary="$(prepare_patched_binary "$binary")"

    template_service="${service_name:-localhost}"
    if [ "$created_exploit" = "1" ]; then
        replace_placeholders "exploit.py" "$patched_binary" "$template_service" "$port"
    fi
    ensure_tmux_conf
    ensure_compose_with_pwnenv "stack.Dockerfile" "$service_name" "" "0" "0"
}

penv_init_heap() {
    local binary created_attach created_exploit patched_binary service_name port ubuntu_version ld_file

    binary="$(detect_binary)"

    [ -f Dockerfile ] || die "Dockerfile not found"
    normalize_compose_file || die "compose.yaml not found"
    copy_mode_file_if_missing heap heap.Dockerfile heap.Dockerfile
    copy_mode_file_if_missing heap Makefile Makefile
    copy_mode_file_if_missing heap gdb.py gdb.py
    copy_mode_file_if_missing heap attach.sh attach.sh created_attach
    copy_mode_file_if_missing heap exploit.py exploit.py created_exploit
    load_compose_context service_name port
    [ -n "$service_name" ] || die "service not found in compose.yaml"
    ubuntu_version="$(get_ubuntu_version Dockerfile)"
    ensure_libc_available "$service_name"
    patched_binary="$(prepare_patched_binary "$binary")"
    ld_file="$(detect_ld_file || true)"
    [ -n "$ld_file" ] || die "ld not found"

    if [ "$created_exploit" = "1" ]; then
        replace_placeholders "exploit.py" "$patched_binary" "localhost" "$port"
    fi
    if [ "$created_attach" = "1" ]; then
        replace_placeholders "attach.sh" "$patched_binary" ""
    fi
    ensure_tmux_conf
    add_pwnenv_service "heap.Dockerfile" "$service_name" "$ubuntu_version" "1" "0"
}

penv_init_kernel() {
    local service_name="" port="" rootfs_file="" rootfs_kind=""

    ensure_run_script
    prepare_kernel_rootfs rootfs_kind rootfs_file
    make_dev_sh
    extract_vmlinux

    copy_mode_file_if_missing kernel kernel.Dockerfile kernel.Dockerfile
    copy_mode_file_if_missing kernel Makefile Makefile
    copy_mode_file_if_missing kernel gdb.py gdb.py
    copy_mode_file_if_missing kernel upload.py upload.py
    copy_mode_files_if_missing kernel .gitignore AGENTS.md

    ensure_kernel_exploit_c
    prepare_kernel_dev_rootfs "$rootfs_kind" "$rootfs_file"
    ensure_tmux_conf
    load_compose_context service_name port

    if [ -f compose.yaml ] && [ -n "$service_name" ]; then
        add_pwnenv_service "kernel.Dockerfile" "$service_name" "" "0" "1"
    else
        ensure_compose_with_pwnenv "kernel.Dockerfile" "" "" "0" "1"
    fi
}

penv_init() {
    if [ "$argc" -ne 2 ]; then
        penv_help >&2
        die "invalid number of arguments"
    fi
    touch "$STATE_FILE"
    case "$mode" in
    bare)
        penv_init_bare
        ;;
    stack)
        penv_init_stack
        ;;
    heap)
        penv_init_heap
        ;;
    kernel)
        penv_init_kernel
        ;;
    *)
        die "unknown mode: $mode"
        ;;
    esac
}

# entry point
cmd="${1:-}"
mode="${2:-}"
argc="$#"
case "$cmd" in
"" | help | --help | -h)
    penv_help
    exit 0
    ;;
init)
    penv_init
    ;;
info)
    penv_info
    ;;
check)
    penv_check
    ;;
clean)
    penv_clean
    ;;
*)
    die "unknown command: $cmd"
    ;;
esac
